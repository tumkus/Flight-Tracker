# SerpApi
SERPAPI_KEY=your_serpapi_key_here

# Sabit rota — sen belirle
FLIGHT_ORIGIN=IST
FLIGHT_DESTINATION=ANK
FLIGHT_DATE=2025-08-15        # YYYY-MM-DD formatında
FLIGHT_CURRENCY=TRY

# Bildirim eşiği — hangisi önce tetiklenirse
PRICE_DROP_PERCENT=10          # %10 düşüş
PRICE_DROP_AMOUNT=200          # 200 TL düşüş

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Vercel KV (Upstash Redis - ücretsiz tier)
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token

# Cron güvenliği
CRON_SECRET=gizli_bir_string_yaz
